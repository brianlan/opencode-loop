{
  "name": "@brianlan/opencode-loop",
  "version": "0.2.0",
  "description": "OpenCode plugin for session-scoped recurring loops",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --declaration",
