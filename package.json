    "@opencode-ai/plugin": "^1.17.8",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "croner": "^10.0.1"
  },
  "bin": {
    "opencode-loop": "bin/install.js"
  },
  "keywords": [
